# ─────────────────────────────────────────────────────────────────────────────
# Ariadne — environment configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Semantic Scholar API key (optional — increases rate limit from 1 to 10 RPS)
# Get a free key at: https://www.semanticscholar.org/product/api
S2_API_KEY=

# OpenAlex mailto (optional but recommended — moves you to the polite pool, 10 RPS)
# Use your real email address
OPENALEX_MAILTO=

# Custom path for the SQLite database (default: ./papers.db next to server.py)
# ARIADNE_DB=

# Directory where PDFs are stored (default: ./pdfs/ next to server.py)
# ARIADNE_PAPERS_DIR=

# Default directory for BibTeX export (default: current working directory)
# ARIADNE_EXPORT_DIR=

# ─────────────────────────────────────────────────────────────────────────────
# LLM Orchestration (Phase 0) — optional but recommended for cost savings
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — enables internal LLM routing for auto-extraction.
# Summarization and key-findings extraction run on cheap models (Haiku)
# instead of consuming your conversation context. Cuts token costs dramatically.
# ANTHROPIC_API_KEY=

# Override the default models for internal extraction tasks
# ARIADNE_FAST_MODEL=claude-haiku-4-5-20251001
# ARIADNE_REASONING_MODEL=claude-sonnet-4-5-20241022

# Confidence threshold for Haiku-to-Sonnet cascade (0-100, default: 75)
# Lower = escalate more often (more expensive, more accurate)
# Higher = escalate less (cheaper, risk of lower quality on complex papers)
# ARIADNE_CASCADE_THRESHOLD=75
